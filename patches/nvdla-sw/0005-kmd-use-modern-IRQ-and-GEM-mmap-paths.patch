From d0fdd11cb760ea6b31cdd7ae6b81daec9b27e77f Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Thu, 25 Jun 2026 17:00:00 +0300
Subject: [PATCH 05/10] kmd: use modern IRQ and GEM mmap paths

Linux 6.x no longer reliably exposes OF interrupts through the legacy
IORESOURCE_IRQ lookup used by the original KMD. The VP device tree contains
an interrupts property, but probe fails with "no irq resource" unless the
driver asks the platform core to translate it.

Use platform_get_irq() first and keep the legacy resource fallback for older
kernels.

Linux 6.x also dispatches drm_gem_mmap() through the GEM object's mmap
callback. The forward-port had pointed the object callback at the legacy
helper which calls drm_gem_mmap_obj(), causing recursive mmap dispatch and
a kernel Oops during GEM mmap. Use the low-level DMA mmap routine as the
modern object mmap callback, use drm_gem_mmap directly in fops, and keep the
legacy wrapper for older kernels and PRIME mmap.

Tested with the modern VP smoke gate on linux-xlnx 6.6.80-ge29e392a4512:
opendla.ko probes, /dev/dri/renderD128 is created, and the GEM create,
map-offset, mmap, read/write, and destroy smoke path completes.

Signed-off-by: Codex <codex@local>
---
 kmd/port/linux/nvdla_core_callbacks.c | 15 ++++++++++-----
 kmd/port/linux/nvdla_gem.c            |  8 +++++++-
 2 files changed, 17 insertions(+), 6 deletions(-)

diff --git a/kmd/port/linux/nvdla_core_callbacks.c b/kmd/port/linux/nvdla_core_callbacks.c
index 5937cec..3a88b8c 100644
--- a/kmd/port/linux/nvdla_core_callbacks.c
+++ b/kmd/port/linux/nvdla_core_callbacks.c
@@ -443,12 +443,17 @@ static int32_t nvdla_probe(struct platform_device *pdev)
 	if (IS_ERR(nvdla_dev->base))
 		return PTR_ERR(nvdla_dev->base);
 
-	res = platform_get_resource(pdev, IORESOURCE_IRQ, 0);
-	if (!res) {
-		dev_err(&pdev->dev, "no irq resource\n");
-		return -EINVAL;
+	err = platform_get_irq(pdev, 0);
+	if (err < 0) {
+		res = platform_get_resource(pdev, IORESOURCE_IRQ, 0);
+		if (!res) {
+			dev_err(&pdev->dev, "no irq resource: %d\n", err);
+			return err;
+		}
+		nvdla_dev->irq = res->start;
+	} else {
+		nvdla_dev->irq = err;
 	}
-	nvdla_dev->irq = res->start;
 
 	err = devm_request_irq(&pdev->dev, nvdla_dev->irq,
 				nvdla_engine_isr, 0,
diff --git a/kmd/port/linux/nvdla_gem.c b/kmd/port/linux/nvdla_gem.c
index 5ffbf0b..0df6d75 100644
--- a/kmd/port/linux/nvdla_gem.c
+++ b/kmd/port/linux/nvdla_gem.c
@@ -307,6 +307,7 @@ static int32_t nvdla_drm_gem_object_mmap(struct drm_gem_object *dobj,
 	return ret;
 }
 
+#if LINUX_VERSION_CODE < KERNEL_VERSION(6, 0, 0)
 static int32_t nvdla_drm_gem_mmap_buf(struct drm_gem_object *obj,
 				struct vm_area_struct *vma)
 {
@@ -332,6 +333,7 @@ static int32_t nvdla_drm_gem_mmap(struct file *filp, struct vm_area_struct *vma)
 
 	return nvdla_drm_gem_object_mmap(obj, vma);
 }
+#endif
 
 static struct sg_table
 *nvdla_drm_gem_prime_get_sg_table(struct drm_gem_object *dobj)
@@ -453,7 +455,7 @@ static const struct drm_gem_object_funcs nvdla_gem_object_funcs = {
 	.get_sg_table = nvdla_drm_gem_prime_get_sg_table,
 	.vmap = nvdla_drm_gem_prime_vmap,
 	.vunmap = nvdla_drm_gem_prime_vunmap,
-	.mmap = nvdla_drm_gem_mmap_buf,
+	.mmap = nvdla_drm_gem_object_mmap,
 	.vm_ops = &nvdla_drm_gem_vm_ops,
 };
 #endif
@@ -463,7 +465,11 @@ static const struct file_operations nvdla_drm_fops = {
 	.open = drm_open,
 	.release = drm_release,
 	.unlocked_ioctl = drm_ioctl,
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 0, 0)
+	.mmap = drm_gem_mmap,
+#else
 	.mmap = nvdla_drm_gem_mmap,
+#endif
 	.poll = drm_poll,
 	.read = drm_read,
 #ifdef CONFIG_COMPAT
