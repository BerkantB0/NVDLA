/ {
    nvdla_0: nvdla@a0000000 {
        compatible = "nvidia,nv_small";
        reg = <0x0 0xa0000000 0x0 0x00010000>;
        interrupts = <0 0 4>; /* Replace with generated GIC SPI from the board DTS. */
        status = "okay";
        /*
         * Do not add dma-coherent for the current XSA. The DBB path reaches
         * DDR through S_AXI_HP0_FPD and the audited PS coherency flags are off.
         */
    };
};

