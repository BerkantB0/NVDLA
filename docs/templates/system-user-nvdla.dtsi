/ {
    nvdla_0: nvdla@a0000000 {
        compatible = "nvidia,nv_small";
        reg = <0x0 0xa0000000 0x0 0x00010000>;
        interrupt-parent = <&gic>;
        interrupts = <0 89 4>; /* XSA pl_ps_irq0 on ZynqMP. */
        status = "okay";
        /*
         * Keep the coherent-DMA property absent for the current XSA. The DBB
         * path reaches DDR through S_AXI_HP0_FPD and the audited PS coherency
         * flags are off.
         */
    };
};
